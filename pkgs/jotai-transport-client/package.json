{
  "name": "jotai-transport-client",
  "version": "0.1.0",
  "description": "Jotai atoms synchronized over a WebSocket transport.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "jotai": "^2.0.0"
  },
  "devDependencies": {
    "jotai": "^2.10.0",
    "typescript": "^5.6.2"
  }
}
