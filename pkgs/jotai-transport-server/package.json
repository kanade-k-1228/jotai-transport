{
  "name": "jotai-transport-server",
  "version": "0.1.0",
  "description": "WebSocket server for synchronizing object state with jotai-transport-client.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@types/ws": "^8.5.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
